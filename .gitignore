# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================
# Dependencies
# =============================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================
# Next.js / Build Output
# =============================
.next/
out/
build/

# =============================
# Testing / Coverage
# =============================
coverage/

# =============================
# Environment Files (NEVER commit secrets)
# =============================
.env*
!.env.example

# =============================
# Logs
# =============================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================
# PM2 / Server Config (local only)
# =============================
ecosystem.config.js

# =============================
# Local Admin / Maintenance
# =============================
scripts/
CHAY_SERVER.bat

# =============================
# Database Dumps / Backups
# =============================
dump/
backups/
*.archive
*.sqlite
*.sqlite3

# =============================
# Certificates / Keys (Security)
# =============================
*.key
*.crt
*.pem

# =============================
# IDE / Editor
# =============================
.vscode/
.idea/
.cursor/

# =============================
# OS Files
# =============================
.DS_Store
Thumbs.db

# =============================
# TypeScript
# =============================
*.tsbuildinfo

# =============================
# Internal Documentation
# =============================
guidelines/

# =============================
# Deployment Platforms
# =============================
.vercel
/generated/prisma
